<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <!-- VIEWPORT CRITIQUE POUR IOS : viewport-fit=cover permet d'utiliser tout l'écran -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    
    <!-- MÉTADONNÉES PWA / IOS -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Block Master">
    <meta name="format-detection" content="telephone=no">
    
    <title>Block Master DX</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Press+Start+2P&family=Vt323&family=Quicksand:wght@700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            /* --- CYBERPUNK DEFAULT --- */
            --bg-color: #050510;
            --text-color: #e0faff;
            --accent-primary: #00f3ff;
            --accent-secondary: #ff00ff;
            --glass-bg: rgba(255, 255, 255, 0.05);
            --font-main: 'Orbitron', sans-serif;
            --btn-bg: rgba(255, 255, 255, 0.1);
            --btn-border: 1px solid rgba(0, 243, 255, 0.5);
            --radius: 12px;
            --shadow-glow: 0 0 10px var(--accent-primary);
            --arrow-fill: transparent;
            --arrow-stroke: #00f3ff;
        }

        /* --- THEME OVERRIDES --- */
        body.gameboy {
            --bg-color: #8b9c0f; --text-color: #0f380f; --accent-primary: #0f380f; --accent-secondary: #306230;
            --glass-bg: transparent; --font-main: 'Press Start 2P', cursive; --btn-bg: #306230; --btn-border: 2px solid #0f380f;
            --radius: 4px; --shadow-glow: none; --arrow-fill: transparent; --arrow-stroke: #1a1a1a;
        }
        body.gbc {
            --bg-color: #663399; /* Atomic Purple */
            --text-color: #000; --accent-primary: #333; --accent-secondary: #555;
            --glass-bg: #f0f0f0; --font-main: 'Press Start 2P', cursive; --btn-bg: #444; --btn-border: none;
            --radius: 20px; --shadow-glow: none; --arrow-fill: transparent; --arrow-stroke: #222;
        }
        body.nes {
            --bg-color: #222; --text-color: #fff; --accent-primary: #d32f2f; --accent-secondary: #fbc02d;
            --glass-bg: #000; --font-main: 'Press Start 2P', cursive; --btn-bg: #555; --btn-border: 4px solid #fff;
            --radius: 0px; --shadow-glow: none; --arrow-fill: transparent; --arrow-stroke: #fff;
        }
        body.pixel {
            --bg-color: #1a1a2e; --text-color: #fff; --accent-primary: #ff4d6d; --accent-secondary: #4cc9f0;
            --glass-bg: rgba(22, 33, 62, 0.8); --font-main: 'Press Start 2P', cursive; --btn-bg: #16213e; --btn-border: 4px solid #fff;
            --radius: 0px; --shadow-glow: 4px 4px 0 rgba(0,0,0,0.5); --arrow-fill: transparent; --arrow-stroke: #fff;
        }
        body.oled {
            --bg-color: #000; --text-color: #fff; --accent-primary: #fff; --accent-secondary: #888;
            --glass-bg: #000; --font-main: 'Orbitron', sans-serif; --btn-bg: #000; --btn-border: 1px solid #fff;
            --radius: 0px; --shadow-glow: none; --arrow-fill: transparent; --arrow-stroke: #fff;
        }
        body.liquid {
            --bg-color: #fce4ec; --text-color: #2c3e50; --accent-primary: #ff6b6b; --accent-secondary: #4ecdc4;
            --glass-bg: rgba(255, 255, 255, 0.25); --font-main: 'Quicksand', sans-serif; --btn-bg: rgba(255, 255, 255, 0.4);
            --btn-border: 1px solid rgba(255, 255, 255, 0.6); --radius: 25px; --shadow-glow: 0 8px 32px rgba(31, 38, 135, 0.15);
            --arrow-fill: transparent; --arrow-stroke: #fff;
        }
        body.liquid { background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab); background-size: 400% 400%; animation: gradientBG 15s ease infinite; }
        @keyframes gradientBG { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }
        
        body.eco-mode { --shadow-glow: none !important; animation: none !important; }
        body.eco-mode * { box-shadow: none !important; text-shadow: none !important; backdrop-filter: none !important; }

        body {
            background-color: var(--bg-color); margin: 0; height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center;
            overflow: hidden; 
            /* Empêche les comportements natifs indésirables */
            touch-action: none; 
            -webkit-user-select: none; user-select: none;
            -webkit-touch-callout: none;
            
            color: var(--text-color); font-family: var(--font-main); transition: background 0.3s;
            
            /* GESTION SAFE AREA IOS (Encoche et Barre du bas) */
            padding-top: env(safe-area-inset-top);
            padding-bottom: env(safe-area-inset-bottom);
            padding-left: env(safe-area-inset-left);
            padding-right: env(safe-area-inset-right);
        }

        /* --- LAYOUT --- */
        #game-wrapper { position: relative; display: flex; padding: 20px; transition: all 0.3s; gap: 20px; align-items: flex-start; }
        
        body.cyberpunk #game-wrapper, body.oled #game-wrapper {
            background-image: linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 30px 30px; padding: 10px;
        }
        body.gameboy #game-wrapper {
            background-color: #9bbc0f; border: 4px solid #0f380f; box-shadow: 0 0 0 12px #c4cfa1, 0 0 0 16px #8b9c0f, 20px 20px 0 rgba(0,0,0,0.2); border-radius: 4px 4px 40px 4px; padding: 15px; gap: 5px; align-items: flex-end;
        }
        body.gbc #game-wrapper {
            background-color: #dedede; border: 10px solid #444; box-shadow: 0 0 0 15px #663399, inset 2px 2px 5px rgba(0,0,0,0.5), 20px 20px 0 rgba(0,0,0,0.2); border-radius: 5px 5px 40px 5px; padding: 0; gap: 0;
        }
        /* Renommé pour éviter le copyright */
        body.gbc #game-wrapper::before {
            content: "POCKET COLOR"; position: absolute; top: 12px; left: 50%; transform: translateX(-50%); color: #ccc; font-size: 10px; font-family: sans-serif; font-style: italic; font-weight:900; z-index: 10; text-shadow: 1px 1px 0 rgba(0,0,0,0.5); width:100%; text-align:center;
        }
        body.gbc #game-wrapper::after { content: "🔴"; font-size: 6px; position:absolute; top: 35%; left: 8px; opacity: 0.8; animation: blink 2s infinite; }
        @keyframes blink { 50% { opacity: 0.3; } }
        body.pixel #game-wrapper {
            background: linear-gradient(to bottom, #2e2b44, #1a1a2e); padding: 15px; border: 4px solid #fff; box-shadow: 10px 10px 0 #000;
        }
        body.liquid #game-wrapper { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(20px); border-radius: 30px; box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.2); border: 1px solid rgba(255, 255, 255, 0.18); padding: 25px; gap: 25px; }

        /* --- CANVAS --- */
        canvas#tetris { display: block; background: rgba(0, 0, 0, 0.8); border: 2px solid var(--accent-primary); width: 200px; height: 400px; image-rendering: pixelated; box-shadow: var(--shadow-glow); }
        body.gameboy canvas#tetris { background: #9bbc0f; border: 2px solid #0f380f; border-right: none; opacity: 0.9; box-shadow: inset 2px 2px 5px rgba(0,0,0,0.1); }
        body.gbc canvas#tetris { background: #fff; border: none; border-right: 1px solid #aaa; box-shadow: none; margin-top: 30px; }
        body.oled canvas#tetris { background: #000; border: 2px solid #fff; box-shadow: none; }
        body.nes canvas#tetris { background: #000; border: 4px solid #fff; box-shadow: none; }
        body.pixel canvas#tetris { background: rgba(0,0,0,0.3); border: 4px solid #fff; box-shadow: none; }
        body.liquid canvas#tetris { background: rgba(255, 255, 255, 0.2); border: 1px solid rgba(255,255,255,0.5); border-radius: 15px; box-shadow: inset 0 0 20px rgba(255,255,255,0.2); image-rendering: auto; }

        /* --- UI PANEL --- */
        #ui-panel { display: flex; flex-direction: column; width: 110px; gap: 15px; justify-content: flex-start; }
        body.gameboy #ui-panel { border: 2px solid #0f380f; border-left: 2px solid #306230; background: #9bbc0f; height: 400px; width: 120px; padding: 5px; gap: 10px; box-sizing: border-box; }
        body.gbc #ui-panel { background: #dedede; height: 400px; padding: 10px; gap: 10px; box-sizing: border-box; border-left: 1px solid #aaa; margin-top: 30px; }
        
        .hud-box { background: var(--glass-bg); padding: 10px; border-radius: var(--radius); text-align: center; border: 1px solid rgba(255,255,255,0.05); backdrop-filter: blur(5px); }
        body.gameboy .hud-box, body.gbc .hud-box { background: transparent; border: none; text-align: right; padding: 5px 0; backdrop-filter: none; }
        body.oled .hud-box { border: 1px solid #fff; }
        body.nes .hud-box { background: #000; border: 2px solid #fff; box-shadow: none; color: #fff; text-align: left; padding: 5px; }
        body.pixel .hud-box { background: #2e2b44; border: 2px solid #fff; box-shadow: 4px 4px 0 rgba(0,0,0,0.5); color: #fff; }
        body.liquid .hud-box { background: rgba(255,255,255,0.3); border: 1px solid rgba(255,255,255,0.4); color: #2c3e50; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }

        .hud-label { font-size: 0.7rem; color: var(--accent-primary); margin-bottom: 5px; letter-spacing: 1px; }
        .hud-value { font-size: 1.2rem; font-weight: bold; }

        /* --- OVERLAY --- */
        #overlay, #settings-modal, #game-over-modal {
            position: absolute; top:0; left:0; width:100%; height:100%; background: rgba(0,0,0,0.9); backdrop-filter: blur(8px); z-index: 100; display: flex; flex-direction: column; align-items: center; justify-content: center; transition: opacity 0.3s;
            /* Respect Safe Area for fullscreen overlays */
            padding-top: env(safe-area-inset-top);
            padding-bottom: env(safe-area-inset-bottom);
        }
        body.gameboy #overlay, body.gameboy #game-over-modal { background: #9bbc0f; backdrop-filter: none; }
        body.gbc #overlay, body.gbc #game-over-modal { background: #dedede; backdrop-filter: none; }
        body.oled #overlay, body.oled #game-over-modal { background: #000; backdrop-filter: none; }
        body.pixel #overlay, body.pixel #game-over-modal { background: rgba(30, 20, 50, 0.95); }
        body.liquid #overlay, body.liquid #game-over-modal { background: rgba(255,255,255,0.6); backdrop-filter: blur(20px); }

        .menu-container { width: 85%; max-width: 350px; text-align: center; }
        /* GENERIC TITLE */
        h1 { font-size: 2.5rem; margin-bottom: 20px; text-shadow: 0 0 15px var(--accent-secondary); color: var(--accent-primary); text-transform: uppercase; letter-spacing: 2px; line-height: 1; }
        body.gbc h1 { background: linear-gradient(to right, #f00, #ff0, #0f0, #00f); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-shadow: 2px 2px 0px rgba(0,0,0,0.1); font-family: 'Press Start 2P', cursive; }
        body.oled h1 { text-shadow: none; }
        body.pixel h1 { color: #fff; text-shadow: 4px 4px 0 #ff4d6d; font-family: 'Press Start 2P', cursive; line-height: 1.5; }
        body.liquid h1 { color: #fff; text-shadow: 0 2px 10px rgba(0,0,0,0.2); letter-spacing: 0; font-weight: 700; }

        .high-score-display { background: var(--btn-bg); padding: 15px; margin-bottom: 25px; border-radius: var(--radius); color: var(--text-color); border: var(--btn-border); }

        button, select { width: 100%; padding: 12px; margin: 6px 0; background: var(--btn-bg); border: var(--btn-border); color: var(--text-color); font-family: inherit; font-size: 0.85rem; cursor: pointer; border-radius: var(--radius); box-shadow: 0 4px 10px rgba(0,0,0,0.3); text-transform: uppercase; transition: all 0.2s ease; font-weight: bold; }
        button:hover:not(:disabled) { filter: brightness(1.2); transform: translateY(-2px); }
        button:active:not(:disabled) { transform: translateY(2px); box-shadow: 0 1px 2px rgba(0,0,0,0.3); }
        
        button:disabled, select:disabled { 
            opacity: 0.4; cursor: not-allowed; filter: grayscale(1); 
            background: #333 !important; color: #888 !important; border: 1px solid #555 !important;
        }
        
        body.gameboy button { color: #9bbc0f; box-shadow: 3px 3px 0 #0f380f; }
        body.gbc button { background: #663399; color: #fff; border: 2px solid rgba(255,255,255,0.2); border-radius: 30px; box-shadow: 0 4px 0 #331a4d; }
        body.gbc button:active:not(:disabled) { box-shadow: 0 0 0 #331a4d; }
        body.oled button { background: #000; border: 2px solid #fff; color: #fff; box-shadow: none; }
        body.oled button:hover:not(:disabled) { background: #fff; color: #000; }
        body.nes button { background: #b71c1c; border: 4px solid #fff; color: #fff; box-shadow: 4px 4px 0 #000; border-radius: 0; }
        body.nes button:active:not(:disabled) { transform: translate(4px, 4px); box-shadow: none; }
        body.pixel button { background: #4cc9f0; border: 4px solid #fff; color: #000; box-shadow: 4px 4px 0 rgba(0,0,0,0.5); border-radius: 0; }
        body.pixel button:active:not(:disabled) { transform: translate(4px, 4px); box-shadow: none; }
        body.liquid button, body.liquid select { background: rgba(255,255,255,0.5); border: 1px solid #fff; color: #333; box-shadow: 0 8px 16px rgba(0,0,0,0.1); }
        
        .btn-play { background: var(--accent-primary); color: var(--bg-color); font-size: 1.1rem; margin-top: 15px; box-shadow: 0 0 20px var(--accent-primary); border: none; padding: 15px; }
        body.oled .btn-play { background: #fff; color: #000; box-shadow: none; }
        body.gbc .btn-play { background: linear-gradient(#ff0055, #cc0044); color: white; box-shadow: 0 5px 0 #990033; border:none; }
        body.pixel .btn-play { background: #ff4d6d; color: #fff; }
        body.liquid .btn-play { background: #fff; color: #ff6b6b; border: 2px solid #ff6b6b; }
        
        .settings-icon-btn { position: absolute; top: 20px; right: 20px; width: 40px; height: 40px; border-radius: 50%; padding: 0; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }

        /* --- CONTROLS --- */
        #mobile-controls { display: none; width: 100%; max-width: 450px; margin-top: 25px; padding: 0 20px; justify-content: space-between; box-sizing: border-box; align-items: center; padding-bottom: calc(20px + env(safe-area-inset-bottom)); }
        @media (max-width: 800px) { #mobile-controls { display: flex; } }
        
        .d-pad { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0px; width: 160px; }
        .ctrl-btn { height: 55px; width: 55px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; user-select: none; transition: transform 0.1s; position: relative; -webkit-tap-highlight-color: transparent; }
        
        /* New Rounded SVG Arrows */
        .svg-arrow { width: 34px; height: 34px; pointer-events: none; fill: var(--arrow-fill); stroke: var(--arrow-stroke); stroke-width: 3px; stroke-linecap: round; stroke-linejoin: round; }

        /* Cyberpunk */
        body.cyberpunk .ctrl-btn { background: rgba(0, 243, 255, 0.1); border: 1px solid var(--accent-primary); border-radius: 12px; margin: 4px; box-shadow: 0 0 10px rgba(0, 243, 255, 0.2); }
        body.cyberpunk .ctrl-btn:active { background: var(--accent-primary); box-shadow: 0 0 15px var(--accent-primary); }
        body.cyberpunk .ctrl-btn:active .svg-arrow { fill: #000; }

        /* GBC / GB AUTHENTIC D-PAD CROSS */
        body.gameboy .d-pad, body.gbc .d-pad { background: transparent; gap: 0; }
        body.gameboy .ctrl-btn, body.gbc .ctrl-btn { background: #222; border: none; box-shadow: none; border-radius: 0; margin: 0; }
        body.gameboy .d-pad div:nth-child(2), body.gbc .d-pad div:nth-child(2) { background: #222; border-radius: 4px 4px 0 0; opacity: 1; visibility: visible !important; pointer-events: none; }
        body.gameboy #btn-left, body.gbc #btn-left { border-radius: 4px 0 0 4px; }
        body.gameboy #btn-right, body.gbc #btn-right { border-radius: 0 4px 4px 0; }
        body.gameboy #btn-down, body.gbc #btn-down { border-radius: 0 0 4px 4px; }
        body.gameboy .d-pad div:nth-child(5), body.gbc .d-pad div:nth-child(5) { background: #222; visibility: visible !important; background-image: radial-gradient(circle, #1a1a1a 20%, #222 60%); }
        body.gameboy .svg-arrow, body.gbc .svg-arrow { fill: none; stroke: #444; stroke-width: 4px; width: 24px; height: 24px; }
        body.gameboy .ctrl-btn:active, body.gbc .ctrl-btn:active { background: #111; }

        body.nes .ctrl-btn { background: #111; border-radius: 0; border: 2px solid #fff; margin: 2px; }
        body.nes .ctrl-btn:active { background: #333; }
        
        body.oled .ctrl-btn { background: #000; border: 1px solid #fff; border-radius: 50%; margin: 4px; }
        body.oled .ctrl-btn:active { background: #fff; }
        body.oled .ctrl-btn:active .svg-arrow { stroke: #000; fill: #000; }
        
        body.pixel .ctrl-btn { background: #4cc9f0; border: 4px solid #fff; border-radius: 0; margin: 4px; box-shadow: 4px 4px 0 rgba(0,0,0,0.5); }
        body.pixel .ctrl-btn:active { transform: translate(4px, 4px); box-shadow: none; }
        body.pixel .svg-arrow { fill: #000; stroke: none; }
        
        body.liquid .ctrl-btn { background: rgba(255,255,255,0.4); border: 1px solid #fff; border-radius: 50%; margin: 5px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        body.liquid .ctrl-btn:active { background: #fff; transform: scale(0.9); }
        body.liquid .svg-arrow { fill: none; stroke: #fff; filter: drop-shadow(0 2px 2px rgba(0,0,0,0.2)); }
        
        .round-btn { width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; font-weight: bold; transition: all 0.1s; -webkit-tap-highlight-color: transparent; }
        body.cyberpunk .round-btn { border: 2px solid var(--accent-secondary); color: var(--accent-secondary); background: rgba(255, 0, 255, 0.1); box-shadow: 0 0 15px var(--accent-secondary); }
        body.cyberpunk .round-btn:active { background: var(--accent-secondary); color: #000; }
        body.gameboy .round-btn { background: #8b1d1d; color: #9bbc0f; box-shadow: 2px 4px 0 #521111; border: none; }
        body.gameboy .round-btn:active { transform: translateY(4px); box-shadow: none; }
        body.gbc .round-btn { background: #333; color: #666; box-shadow: 0 4px 0 #1a1a1a; border: none; background-image: radial-gradient(circle at 30% 30%, #444, #222); }
        body.gbc .round-btn:active { transform: translateY(4px); box-shadow: none; }
        body.nes .round-btn { background: #b71c1c; border: 4px solid #fff; color: #fff; box-shadow: 4px 4px 0 #000; border-radius: 50%; }
        body.nes .round-btn:active { transform: translate(4px, 4px); box-shadow: none; }
        body.pixel .round-btn { background: #ff4d6d; border: 4px solid #fff; color: #fff; box-shadow: 4px 4px 0 rgba(0,0,0,0.5); border-radius: 50%; }
        body.pixel .round-btn:active { transform: translate(4px, 4px); box-shadow: none; }
        body.oled .round-btn { background: #000; border: 2px solid #fff; color: #fff; }
        body.oled .round-btn:active { background: #fff; color: #000; }
        body.liquid .round-btn { background: rgba(255,255,255,0.4); border: 2px solid #fff; color: #fff; box-shadow: 0 8px 16px rgba(0,0,0,0.1); }
        body.liquid .round-btn:active { transform: scale(0.9); background: #fff; color: #ff6b6b; }

        .hidden { display: none !important; }
        .swapped { flex-direction: row-reverse; }
        input[type=range] { width: 100%; margin: 10px 0; accent-color: var(--accent-primary); }
        .checkbox-wrapper { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
        .switch { position: relative; display: inline-block; width: 50px; height: 24px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #555; transition: .4s; border-radius: 24px; }
        .slider:before { position: absolute; content: ""; height: 16px; width: 16px; left: 4px; bottom: 4px; background-color: white; transition: .4s; border-radius: 50%; }
        input:checked + .slider { background-color: var(--accent-primary); }
        input:checked + .slider:before { transform: translateX(26px); }

    </style>
</head>
<body class="cyberpunk">

    <!-- MENU PRINCIPAL -->
    <div id="overlay">
        <div class="menu-container">
            <button class="settings-icon-btn" onclick="app.toggleSettings()">⚙️</button>

            <h1>BLOCK MASTER<br><span style="font-size:0.5em">DX</span></h1>
            
            <div class="high-score-display">
                MEILLEUR SCORE<br>
                <span id="menu-highscore" style="font-size: 1.5rem; font-weight:bold;">0</span>
            </div>

            <div id="game-over-msg" class="hidden" style="margin-bottom:15px; color:var(--accent-secondary); font-weight:bold;">
                FIN DE PARTIE - SCORE: <span id="final-score">0</span>
            </div>

            <select id="theme-select" onchange="app.changeTheme()">
                <option value="cyberpunk">Cyberpunk</option>
                <option value="gbc">Game Boy Color</option>
                <option value="gameboy">Game Boy</option>
                <option value="nes">NES</option>
                <option value="pixel">Pixel Art</option>
                <option value="liquid">Liquid Glass</option>
                <option value="oled">OLED</option>
            </select>

            <select id="mode-select">
                <option value="marathon">Marathon</option>
                <option value="sprint">Sprint (40 Lignes)</option>
                <option value="ultra">Ultra (3 Minutes)</option>
            </select>
            
            <button class="btn-play" onclick="app.start()">JOUER</button>
            <button onclick="app.toggleControls()" id="btn-swap">Cmd: Droite ⇄</button>
        </div>
    </div>

    <!-- GAME OVER MENU -->
    <div id="game-over-modal" class="hidden">
        <div class="menu-container">
            <h1 style="color:var(--accent-secondary)">FIN DE PARTIE</h1>
            
            <div class="high-score-display">
                SCORE FINAL<br>
                <span id="final-score" style="font-size: 2rem; font-weight:bold;">0</span>
            </div>
            
            <div style="margin-bottom:20px; font-size:0.9rem; opacity:0.8">
                MEILLEUR: <span id="go-highscore">0</span>
            </div>

            <button class="btn-play" onclick="app.start()">REJOUER</button>
            <button onclick="app.showMenu()">MENU PRINCIPAL</button>
        </div>
    </div>

    <!-- PARAMETRES -->
