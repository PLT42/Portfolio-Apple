                <!-- Rounded Rotate -->
                <svg class="svg-arrow" style="width:32px;height:32px" viewBox="0 0 24 24"><path d="M21 12a9 9 0 11-9-9c2.52 0 4.93 1 6.74 2.74L21 8" fill="none" /><path d="M21 3v5h-5" fill="none" /></svg>
            </div>
        </div>
    </div>

    <script>
        // --- AUDIO ENGINE PRO ---
        const audio = {
            ctx: null, musicVol: 0.25, sfxVol: 0.4,
            init: function() { 
                if (!this.ctx) this.ctx = new (window.AudioContext || window.webkitAudioContext)(); 
                if (this.ctx.state === 'suspended') this.ctx.resume(); 
            },
            
            getWave: function() {
                const t = document.body.className;
                if(t.includes('gameboy') || t.includes('nes') || t.includes('gbc') || t.includes('pixel')) return 'square';
                return 'sawtooth'; 
            },

            playOsc: function(freq, type, dur, vol=1, slide=0) {
                if(!this.ctx) return;
                const o = this.ctx.createOscillator(), g = this.ctx.createGain();
                o.type = type;
                o.frequency.setValueAtTime(freq, this.ctx.currentTime);
                if(slide) o.frequency.exponentialRampToValueAtTime(freq + slide, this.ctx.currentTime + dur);
                g.gain.setValueAtTime(this.sfxVol * vol, this.ctx.currentTime);
                g.gain.exponentialRampToValueAtTime(0.01, this.ctx.currentTime + dur);
                o.connect(g); g.connect(this.ctx.destination);
                o.start(); o.stop(this.ctx.currentTime + dur);
            },

            sfxMove: function() { this.playOsc(400, this.getWave(), 0.05, 0.3); },
            sfxRotate: function() { this.playOsc(600, this.getWave(), 0.08, 0.3, 100); },
            sfxDrop: function() { 
                if(this.getWave() === 'square') this.playOsc(150, 'square', 0.1, 0.5, -50); 
                else this.playOsc(100, 'sawtooth', 0.15, 0.5, -50);
            }, 
            sfxLine: function() { 
                const w = this.getWave();
                this.playOsc(880, w, 0.1, 0.4); 
                setTimeout(()=>this.playOsc(1108, w, 0.1, 0.4), 60); 
                setTimeout(()=>this.playOsc(1318, w, 0.2, 0.4), 120);
            },
            sfxGameOver: function() { 
                this.playOsc(500, 'sawtooth', 0.3, 0.6);
                setTimeout(()=>this.playOsc(450, 'sawtooth', 0.3, 0.6), 250);
                setTimeout(()=>this.playOsc(300, 'sawtooth', 0.8, 0.6, -100), 500);
            },
            
            // Music Sequencer
            isPlaying: false, noteIndex: 0, nextNoteTime: 0, tempo: 160, currentTrack: 'menu',
            menuMelody: [
                {f:330,d:4},{f:294,d:4},{f:262,d:4},{f:196,d:8},{f:262,d:4},{f:294,d:4},{f:330,d:4},{f:392,d:8}
            ],
            // FULL Korobeiniki (Theme A)
            gameMelody: [
                // Part A
                {f:659,d:4},{f:493,d:2},{f:523,d:2},{f:587,d:4},{f:523,d:2},{f:493,d:2},{f:440,d:4},{f:440,d:2},{f:523,d:2},{f:659,d:4},{f:587,d:2},{f:523,d:2},
                {f:493,d:6},{f:523,d:2},{f:587,d:4},{f:659,d:4},{f:523,d:4},{f:440,d:4},{f:440,d:8},
                {f:0,d:2},{f:587,d:4},{f:698,d:2},{f:880,d:4},{f:783,d:2},{f:698,d:2},{f:659,d:6},{f:523,d:2},{f:659,d:4},{f:587,d:2},{f:523,d:2},
                {f:493,d:4},{f:493,d:2},{f:523,d:2},{f:587,d:4},{f:659,d:4},{f:523,d:4},{f:440,d:4},{f:440,d:8},
                // Part B
                {f:330,d:4},{f:330,d:4},{f:440,d:4},{f:493,d:4},{f:523,d:4},{f:493,d:4},{f:440,d:4},{f:330,d:4},
                {f:330,d:4},{f:330,d:4},{f:440,d:4},{f:493,d:4},{f:523,d:4},{f:659,d:4},{f:440,d:8}
            ],
            
            playTrack: function(track) {
                this.currentTrack = track; this.noteIndex = 0;
                if(this.ctx) this.nextNoteTime = this.ctx.currentTime;
                if(!this.isPlaying) this.startMusic();
            },
            startMusic: function() { if(this.isPlaying||!this.ctx)return; this.isPlaying=true; this.nextNoteTime=this.ctx.currentTime; this.scheduler(); },
            stopMusic: function() { this.isPlaying=false; if(this.tId) clearTimeout(this.tId); },
            scheduler: function() { if(!this.isPlaying)return; while(this.nextNoteTime<this.ctx.currentTime+0.1){this.playNote();} this.tId=setTimeout(()=>this.scheduler(),25); },
            playNote: function() {
                const melody = this.currentTrack === 'menu' ? this.menuMelody : this.gameMelody;
                const n = melody[this.noteIndex % melody.length];
                if(n.f>0){
                    const o=this.ctx.createOscillator(), g=this.ctx.createGain();
                    o.type=this.getWave(); 
                    if(document.body.className==='liquid') o.type = 'sine'; 
                    o.frequency.value=n.f;
                    g.gain.setValueAtTime(this.musicVol, this.nextNoteTime);
                    // Staccato for dynamic feel
                    g.gain.exponentialRampToValueAtTime(0.01, this.nextNoteTime+(n.d*0.08));
                    o.connect(g); g.connect(this.ctx.destination);
                    o.start(this.nextNoteTime); o.stop(this.nextNoteTime+(n.d*0.1));
                }
                const t = this.currentTrack === 'menu' ? 100 : this.tempo;
                this.nextNoteTime+=0.25*n.d*(60.0/t)*2;
                this.noteIndex++;
            },
            setMusicVol: function(v) { this.musicVol=v/200; }, setSfxVol: function(v) { this.sfxVol=v/100; }
        };

        // --- GAME ENGINE ---
        const canvas = document.getElementById('tetris'), ctx = canvas.getContext('2d');
        const nextCtx = document.getElementById('next-canvas').getContext('2d');
        const SCALE = 20;
        ctx.scale(SCALE, SCALE); nextCtx.scale(SCALE, SCALE);

        const PALETTES = {
            cyberpunk: [null,'#FF0055','#00FFFF','#00FF66','#AA00FF','#FF6600','#FFFF00','#0055FF'],
            gameboy: [null,'#0f380f','#0f380f','#0f380f','#0f380f','#0f380f','#0f380f','#0f380f'],
            gbc: [null,'#F00','#0FF','#0F0','#F0F','#F80','#FF0','#00F'],
            nes: [null,'#F00','#0FF','#0F0','#F0F','#F80','#FF0','#00F'], 
            pixel: [null, '#ff4d6d', '#3ee0d6', '#a9f857', '#f9c74f', '#f72585', '#4cc9f0', '#7209b7'],
            oled: [null,'#FFF','#FFF','#FFF','#FFF','#FFF','#FFF','#FFF']
        };

        const app = {
            arena: null, player: {pos:{x:0,y:0},matrix:null,score:0,lines:0,level:1},
            nextPiece: null, gameOver: false, paused: true, isClearing: false,
            mode: 'marathon', modeVal: 0, lastTime: 0, dropCount: 0, highScore: 0,
            targetFPS: 60, frameInterval: 1000/60, animations: [], hapticEnabled: true, detectedHz: 60, rafId: null,

            init: function() {
                this.arena = this.createMatrix(10, 20);
                this.highScore = parseInt(localStorage.getItem('tetris_highscore')) || 0;
                document.getElementById('menu-highscore').innerText = this.highScore;
                this.detectHardware();
                this.changeTheme(); 
                this.draw();
                
                // Gestionnaire d'interaction pour débloquer l'audio (iOS/Chrome policy)
                const startAudio = () => {
                    if(!audio.ctx) audio.init();
                    if(audio.ctx && audio.ctx.state === 'suspended') audio.ctx.resume();
                    
                    // Lancer la musique du menu si on n'est pas déjà en jeu
                    if(this.paused && !this.gameOver && !audio.isPlaying) {
                        audio.playTrack('menu');
                    }
                    
                    document.removeEventListener('click', startAudio);
                    document.removeEventListener('touchstart', startAudio);
                    document.removeEventListener('keydown', startAudio);
                };
                
                document.addEventListener('click', startAudio);
                document.addEventListener('touchstart', startAudio);
                document.addEventListener('keydown', startAudio);
            },

            detectHardware: function() {
                let frames = 0, start = performance.now();
                const check = () => {
                    frames++;
                    if(performance.now() - start >= 1000) {
                        const hz = Math.round(frames);
                        let detected = 60;
                        if(hz > 130) detected = 144;
                        else if(hz > 100) detected = 120;
                        else if(hz > 75) detected = 90;
                        this.detectedHz = detected;
                        document.getElementById('detected-hz').innerText = detected;
                        this.updateFpsOptions(detected);
                        this.setFPS(detected);
                    } else {
                        requestAnimationFrame(check);
                    }
                };
                requestAnimationFrame(check);
            },

            updateFpsOptions: function(maxHz) {
                const select = document.getElementById('fps-select');
                for (let i = 0; i < select.options.length; i++) {
                    const optVal = parseInt(select.options[i].value);
                    if (optVal > maxHz) {
                        select.options[i].disabled = true;
                    } else {
                        select.options[i].disabled = false;
                        if(optVal === maxHz) select.selectedIndex = i;
                    }
                }
            },

            setFPS: function(hz) { this.targetFPS = parseInt(hz); this.frameInterval = 1000/this.targetFPS; },
            toggleEco: function(on) { if(on){this.setFPS(30); document.body.classList.add('eco-mode');} else {this.setFPS(document.getElementById('fps-select').value); document.body.classList.remove('eco-mode');} },
            toggleHaptic: function(on) { this.hapticEnabled = on; },

            start: function() {
                audio.init(); audio.playTrack('game');
                this.arena.forEach(r => r.fill(0));
                this.player = {pos:{x:0,y:0},matrix:null,score:0,lines:0,level:1};
                this.gameOver = false; this.paused = false; this.isClearing = false; this.animations = [];
                this.mode = document.getElementById('mode-select').value;
                if(this.mode==='sprint') this.modeVal=40; else if(this.mode==='ultra') this.modeVal=180;
                this.resetPlayer();
                document.getElementById('overlay').classList.add('hidden');
                document.getElementById('game-over-modal').classList.add('hidden');
                this.updateUI(); 
                if(this.rafId) cancelAnimationFrame(this.rafId); 
                this.lastTime = performance.now();
                this.loop(this.lastTime);
            },
            
            showMenu: function() {
                this.gameOver = true;
                if(this.rafId) cancelAnimationFrame(this.rafId);
                audio.playTrack('menu');
                document.getElementById('game-over-modal').classList.add('hidden');
                document.getElementById('overlay').classList.remove('hidden');
                this.draw();
            },

            createMatrix: function(w, h) { const m=[]; while(h--) m.push(new Array(w).fill(0)); return m; },
            createPiece: function(t) {
                if(t==='I')return[[0,1,0,0],[0,1,0,0],[0,1,0,0],[0,1,0,0]];
                if(t==='L')return[[0,2,0],[0,2,0],[0,2,2]]; if(t==='J')return[[0,3,0],[0,3,0],[3,3,0]];
                if(t==='O')return[[4,4],[4,4]]; if(t==='Z')return[[5,5,0],[0,5,5],[0,0,0]];
                if(t==='S')return[[0,6,6],[6,6,0],[0,0,0]]; if(t==='T')return[[0,7,0],[7,7,7],[0,0,0]];
            },

            resetPlayer: function() {
                if(!this.nextPiece) this.nextPiece = this.createPiece('ILJOTSZ'[Math.random()*7|0]);
                this.player.matrix = this.nextPiece;
                this.player.pos.y = 0;
                this.player.pos.x = (this.arena[0].length/2|0)-(this.player.matrix[0].length/2|0);
                this.nextPiece = this.createPiece('ILJOTSZ'[Math.random()*7|0]);
                if(this.collide(this.arena, this.player)) this.endGame();
                this.drawNext();
            },

            collide: function(a, p) {
                const [m, o] = [p.matrix, p.pos];
                for(let y=0; y<m.length; ++y) for(let x=0; x<m[y].length; ++x)
                    if(m[y][x]!==0 && (a[y+o.y] && a[y+o.y][x+o.x])!==0) return true;
                return false;
            },

            merge: function(a, p) {
                p.matrix.forEach((row, y) => row.forEach((val, x) => { if(val!==0) a[y+p.pos.y][x+p.pos.x]=val; }));
                audio.sfxDrop();
                this.player.score += 5; 
                this.updateUI();
            },

            rotate: function(dir) {
                if (this.gameOver || this.paused) return; // Strict Lock
                const pos = this.player.pos.x; let offset = 1;
                this._rot(this.player.matrix, dir);
                while(this.collide(this.arena, this.player)) {
                    this.player.pos.x += offset; offset = -(offset+(offset>0?1:-1));
                    if(offset > this.player.matrix[0].length) { this._rot(this.player.matrix, -dir); this.player.pos.x = pos; return; }
                }
                audio.sfxRotate();
            },
            _rot: function(m, d) { for(let y=0;y<m.length;++y)for(let x=0;x<y;++x)[m[x][y],m[y][x]]=[m[y][x],m[x][y]]; if(d>0)m.forEach(r=>r.reverse());else m.reverse(); },

            drop: function(manual=false) {
                if(this.isClearing || this.gameOver || this.paused) return; // Strict Lock
                this.player.pos.y++;
                if(this.collide(this.arena, this.player)) {
                    this.player.pos.y--;
                    this.merge(this.arena, this.player);
                    this.checkLines();
                } 
                this.dropCount = 0;
            },

            move: function(dir) {
                if(this.isClearing || this.gameOver || this.paused) return; // Strict Lock
                this.player.pos.x += dir;
                if(this.collide(this.arena, this.player)) this.player.pos.x -= dir;
                else audio.sfxMove();
            },

            checkLines: function() {
                let lines = [];
                for(let y=this.arena.length-1; y>0; --y) {
                    let full = true; for(let x=0; x<this.arena[y].length; ++x) if(this.arena[y][x]===0) full=false;
                    if(full) lines.push(y);
                }
                if(lines.length>0) { this.isClearing=true; this.startAnim(lines); }
                else this.resetPlayer();
            },

            startAnim: function(lines) {
                audio.sfxLine();
                this.animations.push({ lines: lines, timer: 0, max: 20 });
            },

            procAnim: function() {
                if(!this.animations.length) return;
                let fin = false;
                this.animations.forEach(a => { a.timer++; if(a.timer>=a.max) fin=true; });
                if(fin) {
                    this.sweep(); this.animations=[]; this.isClearing=false; this.resetPlayer();
                }
            },

            sweep: function() {
                let count = 0;
                outer: for(let y=this.arena.length-1; y>0; --y) {
                    for(let x=0; x<this.arena[y].length; ++x) if(this.arena[y][x]===0) continue outer;
                    const row = this.arena.splice(y, 1)[0].fill(0);
                    this.arena.unshift(row); ++y; count++;
                }
                if(count>0) {
                    const pts = [0, 100, 300, 500, 800];
                    this.player.score += pts[count] * this.player.level;
                    this.player.lines += count;
                    if(this.mode==='sprint') { this.modeVal -= count; if(this.modeVal<=0) this.endGame(); }
                    else this.player.level = Math.floor(this.player.lines/10)+1;
                    this.updateUI();
                }
            },

            loop: function(time) {
                if(this.paused || this.gameOver) {
                    if(this.rafId) cancelAnimationFrame(this.rafId);
                    return; // STOP LOOP
                }
                this.rafId = requestAnimationFrame(t => this.loop(t));

                const dt = time - this.lastTime;
                if (dt < this.frameInterval) return;
                this.lastTime = time - (dt % this.frameInterval);
                this.dropCount += dt;

                let speed = Math.max(100, 1000-(this.player.level*50));
                if(this.mode==='ultra') { this.modeVal -= dt/1000; if(this.modeVal<=0) this.endGame(); this.updateUI(); }

                if(this.isClearing) this.procAnim();
                else if(this.dropCount > speed) this.drop();
                
                this.draw();
            },

            endGame: function() {
                this.gameOver = true;
                if(this.rafId) cancelAnimationFrame(this.rafId); 
                audio.stopMusic(); audio.sfxGameOver();
                if(this.player.score > this.highScore) {
                    this.highScore = this.player.score; localStorage.setItem('tetris_highscore', this.highScore);
                    document.getElementById('menu-highscore').innerText = this.highScore;
                }
                document.getElementById('final-score').innerText = this.player.score;
                document.getElementById('go-highscore').innerText = this.highScore;
                document.getElementById('game-over-modal').classList.remove('hidden');
            },

            updateUI: function() {
                document.getElementById('score').innerText = this.player.score;
                if(this.mode==='sprint') { document.getElementById('lines-label').innerText='RESTANT'; document.getElementById('lines').innerText=Math.max(0,Math.ceil(this.modeVal)); }
                else { document.getElementById('lines-label').innerText='LIGNES'; document.getElementById('lines').innerText=this.player.lines; }
                if(this.mode==='ultra') document.getElementById('level').innerText=Math.ceil(this.modeVal)+'s';
                else document.getElementById('level').innerText=this.player.level;
            },

            changeTheme: function() { document.body.className = document.getElementById('theme-select').value; this.draw(); if(this.nextPiece) this.drawNext(); },
            
            draw: function() {
                const theme = document.body.className;
                ctx.fillStyle = theme==='gameboy'?'#9bbc0f':(theme==='gbc'?'#fff':(theme==='oled'?'#000':'rgba(0,0,0,0.8)'));
                if(theme==='nes') ctx.fillStyle='#000';
                if(theme==='pixel') ctx.fillStyle='rgba(0,0,0,0.5)';
                if(theme==='liquid') ctx.fillStyle='rgba(255,255,255,0.1)';
                ctx.fillRect(0,0,200/SCALE,400/SCALE); 
                
                if(theme==='gbc') {
                    // DX Checkerboard
                    ctx.fillStyle='rgba(0,0,0,0.06)';
                    for(let y=0; y<20; y++) {
                        for(let x=0; x<10; x++) {
                            if((x+y)%2 === 0) ctx.fillRect(x,y,1,1);
                        }
                    }
                }

                this.drawMatrix(this.arena, {x:0,y:0}, ctx);

                if(this.isClearing && this.animations.length) {
                    const anim = this.animations[0];
                    anim.lines.forEach(y => {
                        if(theme==='cyberpunk') {
                            ctx.fillStyle = `rgba(0,243,255,${1-anim.timer/anim.max})`; ctx.fillRect(0,y,10,1);
                        } else if(theme==='gameboy'||theme==='gbc') {
                            ctx.fillStyle = (anim.timer%6<3)?'#0f380f':'#9bbc0f'; ctx.fillRect(0,y,10,1);
                        } else {
                            ctx.fillStyle = (anim.timer%4<2)?'#fff':'#000'; ctx.fillRect(0,y,10,1);
                        }
                    });
                } else if(!this.paused && !this.gameOver) {
                    if(theme!=='gameboy' && theme!=='nes') { 
                        let g={...this.player.pos}; while(!this.collide(this.arena,{pos:g,matrix:this.player.matrix}))g.y++; g.y--;
                        if(g.y!==this.player.pos.y) this.drawMatrix(this.player.matrix, g, ctx, true);
                    }
                    this.drawMatrix(this.player.matrix, this.player.pos, ctx);
                }
            },

            drawNext: function() {
                const theme = document.body.className;
                nextCtx.fillStyle = theme==='gameboy'?'#9bbc0f':'rgba(0,0,0,0)';
                nextCtx.clearRect(0,0,4,4);
                if(theme==='gameboy') nextCtx.fillRect(0,0,4,4);
                if(this.nextPiece) {
                    const ox=(4-this.nextPiece[0].length)/2, oy=(4-this.nextPiece.length)/2;
                    this.drawMatrix(this.nextPiece, {x:ox,y:oy}, nextCtx);
                }
            },

            drawMatrix: function(m, o, c, ghost=false) {
                const theme = document.body.className;
                const pal = PALETTES[theme] || PALETTES.cyberpunk;
                m.forEach((row, y) => row.forEach((val, x) => {
                    if(val!==0) {
                        const X=x+o.x, Y=y+o.y, col=pal[val];
                        if(theme==='gameboy') {
                            c.fillStyle=ghost?'transparent':col;
                            if(!ghost){c.fillRect(X,Y,1,1); c.fillStyle='#9bbc0f'; c.fillRect(X+0.1,Y+0.1,0.8,0.8); c.fillStyle=col; c.fillRect(X+0.3,Y+0.3,0.4,0.4);}
                        } 
                        else if(theme==='gbc') {
                            c.fillStyle=ghost?'rgba(0,0,0,0.1)':col; c.fillRect(X,Y,1,1);
                            if(!ghost){
                                // Tetris DX Style: "Candy" blocks
                                c.fillStyle='rgba(255,255,255,0.9)'; c.fillRect(X,Y,0.2,0.2); // White dot corner
                                c.fillStyle='rgba(0,0,0,0.3)'; c.fillRect(X+0.7,Y+0.7,0.3,0.3); // Inner Shadow
                                c.strokeStyle='#000'; c.lineWidth=0.05; c.strokeRect(X,Y,1,1); // Black Border
                            }
                        } 
                        else if(theme==='nes') {
                            c.fillStyle=ghost?'transparent':col;
                            if(!ghost){
                                // NES Style: White border + solid fill
                                c.fillStyle='white'; c.fillRect(X,Y,1,1);
                                c.fillStyle=col; c.fillRect(X+0.1, Y+0.1, 0.8, 0.8);
                            } else {
                                c.strokeStyle='#fff'; c.lineWidth=0.05; c.strokeRect(X,Y,1,1);
                            }
                        }
                        else if(theme==='pixel') {
                            c.fillStyle=ghost?'rgba(255,255,255,0.2)':col; 
                            if(!ghost){
                                c.fillRect(X,Y,1,1);
                                c.fillStyle='rgba(255,255,255,0.5)'; c.fillRect(X+0.1,Y+0.1,0.2,0.2); 
                                c.fillStyle='rgba(0,0,0,0.2)'; c.fillRect(X+0.8,Y+0.8,0.1,0.1);
                                c.strokeStyle='#000'; c.lineWidth=0.05; c.strokeRect(X,Y,1,1);
                            } else {
                                c.fillRect(X,Y,1,1);
                            }
                        }
                        else if(theme==='liquid') {
                            c.fillStyle=ghost?'rgba(255,255,255,0.2)':col;
                            if(!ghost) {
                                c.beginPath(); c.roundRect(X+0.05, Y+0.05, 0.9, 0.9, 0.3); c.fill();
                                c.fillStyle='rgba(255,255,255,0.6)'; c.beginPath(); c.arc(X+0.3, Y+0.3, 0.15, 0, Math.PI*2); c.fill();
                            } else {
                                c.beginPath(); c.roundRect(X+0.05, Y+0.05, 0.9, 0.9, 0.3); c.fillStyle='rgba(255,255,255,0.1)'; c.fill(); c.strokeStyle='rgba(255,255,255,0.3)'; c.lineWidth=0.05; c.stroke();
                            }
                        }
                        else if(theme==='oled') {
                            if(ghost){c.strokeStyle='#fff'; c.lineWidth=0.05; c.strokeRect(X,Y,1,1);}
                            else{c.fillStyle='#fff'; c.fillRect(X,Y,1,1); c.strokeStyle='#000'; c.lineWidth=0.05; c.strokeRect(X,Y,1,1);}
                        } 
                        else { // Cyberpunk
                            if(ghost){c.strokeStyle=col; c.lineWidth=0.05; c.strokeRect(X,Y,1,1);}
                            else{c.fillStyle=col; c.shadowBlur=10; c.shadowColor=col; c.fillRect(X,Y,1,1); c.shadowBlur=0; c.fillStyle='rgba(255,255,255,0.4)'; c.fillRect(X,Y,1,0.1); c.fillRect(X,Y,0.1,1);}
                        }
                    }
                }));
            },

            toggleSettings: function() { const m=document.getElementById('settings-modal'); m.classList.toggle('hidden'); audio.init(); },
            toggleControls: function() {
                const el=document.getElementById('mobile-controls'), btn=document.getElementById('btn-swap');
                el.classList.toggle('swapped'); btn.innerHTML=el.classList.contains('swapped')?'Cmd: Gauche ⇄':'Cmd: Droite ⇄';
            }
        };

        // --- EVENTS ---
        document.addEventListener('keydown', e => {
            if(app.paused || app.gameOver) return; // Strict block
            if(e.keyCode===37) app.move(-1); else if(e.keyCode===39) app.move(1);
            else if(e.keyCode===40) app.drop(true); else if(e.keyCode===38||e.keyCode===81) app.rotate(1);
        });

        function bindBtn(id, action, repeat=100) {
            const el = document.getElementById(id); let t;
            const s = (e) => { e.preventDefault(); if(app.paused || app.gameOver) return; el.classList.add('active'); action(); if(repeat) t=setInterval(action, repeat); };
            const n = (e) => { e.preventDefault(); el.classList.remove('active'); if(t) clearInterval(t); };
            el.addEventListener('touchstart', s, {passive:false}); el.addEventListener('mousedown', s);
            ['touchend','touchcancel','mouseup','mouseleave'].forEach(ev=>el.addEventListener(ev, n));
        }
        bindBtn('btn-left', ()=>app.move(-1)); bindBtn('btn-right', ()=>app.move(1));
        bindBtn('btn-down', ()=>app.drop(true), 50); bindBtn('btn-rotate', ()=>app.rotate(1), 0);

        app.init();
    </script>
</body>
